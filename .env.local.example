# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit the real file.

# WireGuard keys — generate with: wg genkey | tee private.key | wg pubkey
VPS_PRIVATE_KEY=
VPS_PUBLIC_KEY=
T15P_PRIVATE_KEY=
T15P_PUBLIC_KEY=
MACBOOK_PRIVATE_KEY=
MACBOOK_PUBLIC_KEY=

# Oracle VPS public IP (reserved, does not change)
VPS_SERVER_PUBLIC_IP=

# MR550 WiFi passphrase
AP_PASSPHRASE=
