# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit the real file.

# ── VPS Provider ──────────────────────────────────────────────────────────────
# Which VPS provider to use: ORACLE or HETZNER
VPS_PROVIDER=HETZNER

# ── WireGuard keys ────────────────────────────────────────────────────────────
# Generate with: wg genkey | tee private.key | wg pubkey
# The VPS keys are per-provider (you need new keys for a new VPS)
VPS_PRIVATE_KEY=
VPS_PUBLIC_KEY=
T15P_PRIVATE_KEY=
T15P_PUBLIC_KEY=
MACBOOK_PRIVATE_KEY=
MACBOOK_PUBLIC_KEY=

# ── Active VPS public IP ──────────────────────────────────────────────────────
# This is the IP used by T15p and MacBook WireGuard configs.
# Set this to the public IP of whichever provider is active.
VPS_SERVER_PUBLIC_IP=

# ── Oracle Cloud (only needed if VPS_PROVIDER=ORACLE) ─────────────────────────
ORACLE_TENANCY_OCID=
ORACLE_SUBNET_OCID=
ORACLE_IMAGE_OCID=
ORACLE_VPS_SERVER_PUBLIC_IP=
ORACLE_VPS_PRIVATE_KEY=
ORACLE_VPS_PUBLIC_KEY=

# ── Hetzner Cloud (only needed if VPS_PROVIDER=HETZNER) ──────────────────────
HETZNER_API_KEY=
HETZNER_VPS_SERVER_PUBLIC_IP=
HETZNER_VPS_PRIVATE_KEY=
HETZNER_VPS_PUBLIC_KEY=

# ── MR550 WiFi ────────────────────────────────────────────────────────────────
AP_PASSPHRASE=
